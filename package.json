{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "node scripts/ensure-rollup-native.mjs && vite build && node scripts/build-server.mjs && node scripts/verify-runtime-bundle.mjs",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:real-db": "npm run test:real-db:retention && npm run test:real-db:rehearsal",
    "test:real-db:retention": "vitest run --config vitest.real-db.config.ts server/storage.retention.real-db.test.ts",
    "test:real-db:rehearsal": "vitest run --config vitest.real-db.config.ts server/rehearsal.real-db.test.ts",
    "restore:check": "tsx server/scripts/restore-check.ts",
    "restore:rehearse": "tsx server/scripts/restore-rehearsal.ts",
    "aes:inspect": "node scripts/inspect-employees.mjs",
    "aes:report": "node scripts/migrate-to-aes.mjs",
    "aes:snapshot": "node scripts/migrate-to-aes.mjs --snapshot",
    "aes:rehearse": "node scripts/migrate-to-aes.mjs --rehearse",
    "aes:status": "node scripts/aes-migration-status.mjs",
    "aes:ready": "node scripts/aes-migration-status.mjs --require-ready",
    "aes:migrate": "node scripts/migrate-to-aes.mjs --execute",
    "aes:rollback": "node scripts/migrate-to-aes.mjs --rollback",
    "secrets:generate": "node scripts/generate-secrets.mjs",
    "security:supabase:check": "node scripts/harden-supabase-public-schema.mjs --check",
    "security:supabase:harden": "node scripts/harden-supabase-public-schema.mjs --apply",
    "db:employee-recycle-bin:check": "node scripts/apply-employee-recycle-bin-schema.mjs --check",
    "db:employee-recycle-bin:apply": "node scripts/apply-employee-recycle-bin-schema.mjs --apply",
    "verify:ops": "npm run verify:core && npm run restore:check",
    "verify:baseline": "npm run check && npm run build",
    "verify:ci": "npm run check && npm test && npm run build",
    "verify:release": "npm run verify:ci && npm run test:smoke && npm run restore:check",
    "verify:core": "npm test && npm run verify:baseline",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@line/bot-sdk": "^11.0.0",
    "@line/liff": "^2.28.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-context-menu": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-hover-card": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.1",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.1",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.60.5",
    "@types/pg": "^8.15.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.0",
    "embla-carousel-react": "^8.3.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.2",
    "framer-motion": "^11.13.1",
    "helmet": "^8.1.0",
    "input-otp": "^1.2.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.453.0",
    "nanoid": "^3.3.11",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-icons": "^5.4.0",
    "react-resizable-panels": "^2.1.4",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.0",
    "wouter": "^3.3.5",
    "zod": "^3.23.8",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.15",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "20.16.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.7",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.47",
    "rollup": "^4.60.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "5.6.3",
    "vite": "^6.4.2",
    "vitest": "^4.0.16"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.0",
    "@rollup/rollup-win32-x64-msvc": "^4.60.0",
    "bufferutil": "^4.0.8"
  },
  "overrides": {
    "lodash": "4.18.1",
    "yaml": "^2.8.3",
    "esbuild": "^0.25.0"
  }
}
