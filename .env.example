# =============================================================================
# barcode_scan_V3 — Environment Variable Template
# =============================================================================
# Copy this file to .env for local development.
# Production deployments must use platform secrets — never commit a real .env.
# Generate fresh secrets with: npm run secrets:generate
# =============================================================================

# --- Core ---
NODE_ENV=development
PORT=5000

# --- Database ---
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://<db-user>:<db-password>@localhost:5432/<db-name>

# --- Session ---
# At least 32 random characters. Generate with: npm run secrets:generate
SESSION_SECRET=replace-with-at-least-32-characters
SESSION_SECURE=false          # set true in production (HTTPS only)
SESSION_SAME_SITE=lax         # lax | strict | none
SESSION_TIMEOUT=60            # admin session timeout in minutes
TRUST_PROXY=false             # set true when behind a reverse proxy

# --- Admin PIN ---
# Production: must be a PBKDF2 hash. Generate with: npm run super-pin:hash -- <PIN>
# Development: plaintext is accepted
SUPER_ADMIN_PIN=

# --- AES Encryption (optional) ---
# Enable encrypted storage for employee sensitive fields.
# Generate all three together with: npm run secrets:generate
USE_AES_ENCRYPTION=false
ENCRYPTION_KEY=
ENCRYPTION_SALT=

# --- Backup Protection ---
# At least 32 characters. Falls back to ENCRYPTION_KEY if not set.
BACKUP_ENCRYPTION_KEY=

# --- CORS ---
# Comma-separated list of allowed origins (leave empty to allow all in dev)
ALLOWED_ORIGINS=

# --- Scan Device Token ---
# Optional bearer token for protected barcode kiosk flows
SCAN_DEVICE_TOKEN=

# --- Runtime Paths (optional — defaults shown below) ---
# Production: set these to paths outside the repository workspace
# APP_RUNTIME_DIR=/var/lib/barcode_scan_V3
# APP_BACKUP_DIR=/var/lib/barcode_scan_V3/backups
# APP_LOG_DIR=/var/lib/barcode_scan_V3/logs

# --- PostgreSQL SSL (advanced) ---
# Set false ONLY for known Supabase pooler hosts with untrusted certs
# PGSSLREJECT_UNAUTHORIZED=false

# --- LINE Integration (all five required if using LINE features) ---
# LINE_LOGIN_CHANNEL_ID=
# LINE_LOGIN_CHANNEL_SECRET=
# LINE_LOGIN_CALLBACK_URL=https://your-domain.example.com/api/line/callback
# LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# LINE_MESSAGING_CHANNEL_SECRET=

# --- Emergency Override ---
# Allows .env in production — for break-glass use only
# ALLOW_DOTENV_IN_PRODUCTION=true
